    agent any

    stages {

        stage('Clone') {
            steps {
                echo 'Cloning Project...'
            }
        }

        stage('Build') {
            steps {
                echo 'Building Project...'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing Project...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying Project...'
            }
        }
    }
}
